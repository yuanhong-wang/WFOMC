\forall X: (\forall Y: (A(X) & C(Y) -> (~CIRCULAR_PRED(X,Y) & ~CIRCULAR_PRED(Y,X)))) &
\forall X: (\forall Y: (B(X) & C(Y) -> (~CIRCULAR_PRED(X,Y) & ~CIRCULAR_PRED(Y,X))))


